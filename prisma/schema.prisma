generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                String            @id @default(cuid())
  discordId         String            @unique
  discordUsername   String
  discordNickname   String?
  discordAvatar     String?
  discordServerNick String?
  displayNickname   String?
  /** 관리자 지정 사이트 역할 — null이면 Discord·Teacher·AdminRole 기준 자동 분류 */
  siteRole          String?
  discordRoleNames  String?
  isInGuild         Boolean           @default(false)
  guildJoinedAt     DateTime?
  guildSyncedAt     DateTime?
  status            String            @default("active")
  classId           String?
  class             Class?            @relation(fields: [classId], references: [id])
  teacherId         String?
  teacher           Teacher?          @relation("AssignedTeacher", fields: [teacherId], references: [id])
  applications      Application[]
  interviews        Interview[]
  graduationReview  GraduationReview?
  pointHistories    PointHistory[]
  adminRole         AdminRole?
  adminRoleRequests AdminRoleRequest[]
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
}

model Class {
  id             String         @id @default(cuid())
  slug           String         @unique
  name           String
  game           String
  gameKr         String
  description    String
  users          User[]
  teachers       Teacher[]
  teacherClasses TeacherClass[]
  applications   Application[]
}

/** 공개 인원 표시용 집계 스냅샷 — User·Teacher 원본 데이터는 변경하지 않음 */
model EnrollmentStat {
  entityType  String
  entityId    String
  activeCount Int      @default(0)
  updatedAt   DateTime @updatedAt

  @@id([entityType, entityId])
  @@index([entityType])
}

model Teacher {
  id               String         @id @default(cuid())
  name             String
  profileImage     String?
  mbti             String?
  gender           String?
  region           String?
  birthYear        Int?
  intro            String?
  discord          String?
  discordUserId    String?        @unique
  activityDays     String?
  activityTimeSlot String?
  isActive         Boolean        @default(true)
  maxStudents      Int            @default(5)
  currentStudents  Int            @default(0)
  classId          String
  class            Class          @relation(fields: [classId], references: [id])
  teacherClasses   TeacherClass[]
  assignedUsers    User[]         @relation("AssignedTeacher")
  applications     Application[]
  interviews       Interview[]
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
}

model TeacherClass {
  teacherId String
  classId   String
  teacher   Teacher  @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  class     Class    @relation(fields: [classId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@id([teacherId, classId])
  @@index([classId])
}

model Application {
  id           String   @id @default(cuid())
  userId       String?
  user         User?    @relation(fields: [userId], references: [id])
  nickname     String
  discord      String
  playTimeSlot String?
  teacherId    String
  teacher      Teacher  @relation(fields: [teacherId], references: [id])
  classId      String
  class        Class    @relation(fields: [classId], references: [id])
  status       String   @default("approved")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Interview {
  id                String         @id @default(cuid())
  userId            String
  user              User           @relation(fields: [userId], references: [id])
  nickname          String
  className         String?
  teacherId         String?
  teacher           Teacher?       @relation(fields: [teacherId], references: [id])
  contentExperience String
  memorablePerson   String
  joinedClub        Boolean        @default(false)
  clubNames         String?
  pointHistories    PointHistory[]
  createdAt         DateTime       @default(now())
}

model PointHistory {
  id          String     @id @default(cuid())
  userId      String
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  interviewId String?
  interview   Interview? @relation(fields: [interviewId], references: [id], onDelete: SetNull)
  pointType   String
  pointAmount Int
  createdAt   DateTime   @default(now())

  @@index([userId])
  @@index([pointType])
  @@index([interviewId])
}

model InterviewDeletionLog {
  id                     String   @id @default(cuid())
  interviewId            String
  authorUserId           String
  authorDisplayName      String
  deletedByUserId        String
  deletedByDisplayName   String
  reason                 String?
  graduationPointsRemoved Int     @default(0)
  clubPointsRemoved       Int     @default(0)
  createdAt              DateTime @default(now())

  @@index([authorUserId])
  @@index([deletedByUserId])
}

model GraduationReview {
  id         String   @id @default(cuid())
  userId     String   @unique
  user       User     @relation(fields: [userId], references: [id])
  authorName String
  className  String
  content    String
  createdAt  DateTime @default(now())
}

model AdminRole {
  id          String   @id @default(cuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  grantedById String?
  createdAt   DateTime @default(now())
}

model AdminRoleRequest {
  id           String    @id @default(cuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  status       String    @default("pending")
  message      String?
  reviewedById String?
  reviewedAt   DateTime?
  reviewNote   String?
  createdAt    DateTime  @default(now())

  @@index([userId])
  @@index([status])
}

model AdminRoleAuditLog {
  id           String   @id @default(cuid())
  action       String
  targetUserId String
  actorUserId  String
  requestId    String?
  note         String?
  createdAt    DateTime @default(now())

  @@index([targetUserId])
  @@index([actorUserId])
  @@index([action])
}

model SiteSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

model ContentPost {
  id           String         @id @default(cuid())
  title        String
  summary      String?
  body         String         @default("")
  thumbnailUrl String?
  published    Boolean        @default(true)
  images       ContentImage[]
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  @@index([published, createdAt])
}

model ContentImage {
  id        String      @id @default(cuid())
  postId    String
  post      ContentPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  url       String
  sortOrder Int         @default(0)
  createdAt DateTime    @default(now())

  @@index([postId, sortOrder])
}

/** Vercel Blob 미연결 시 컨텐츠 이미지 바이너리 저장 (기존 ContentPost/Image URL 방식 유지) */
model ContentUploadedFile {
  id        String   @id @default(cuid())
  mimeType  String
  data      Bytes
  size      Int
  createdAt DateTime @default(now())

  @@index([createdAt])
}
