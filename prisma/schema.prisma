generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                String            @id @default(cuid())
  discordId         String            @unique
  discordUsername   String
  discordNickname   String?
  discordAvatar     String?
  discordServerNick String?
  discordRoleNames  String?
  siteDisplayName   String?
  isInGuild         Boolean           @default(false)
  guildSyncedAt     DateTime?
  status            String            @default("active")
  classId           String?
  class             Class?            @relation(fields: [classId], references: [id])
  teacherId         String?
  teacher           Teacher?          @relation("AssignedTeacher", fields: [teacherId], references: [id])
  applications      Application[]
  interviews        Interview[]
  graduationReview  GraduationReview?
  pointHistories    PointHistory[]
  adminRole         AdminRole?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
}

model Class {
  id           String        @id @default(cuid())
  slug         String        @unique
  name         String
  game         String
  gameKr       String
  description  String
  users        User[]
  teachers     Teacher[]
  applications Application[]
}

model Teacher {
  id               String        @id @default(cuid())
  name             String
  profileImage     String?
  mbti             String?
  intro            String?
  discord          String?
  activityDays     String?
  activityTimeSlot String?
  isActive         Boolean       @default(true)
  maxStudents      Int           @default(5)
  currentStudents  Int           @default(0)
  classId          String
  class            Class         @relation(fields: [classId], references: [id])
  assignedUsers    User[]        @relation("AssignedTeacher")
  applications     Application[]
  interviews       Interview[]
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
}

model Application {
  id           String   @id @default(cuid())
  userId       String?
  user         User?    @relation(fields: [userId], references: [id])
  nickname     String
  discord      String
  playTimeSlot String?
  teacherId    String
  teacher      Teacher  @relation(fields: [teacherId], references: [id])
  classId      String
  class        Class    @relation(fields: [classId], references: [id])
  status       String   @default("approved")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Interview {
  id                String   @id @default(cuid())
  userId            String
  user              User     @relation(fields: [userId], references: [id])
  nickname          String
  className         String?
  teacherId         String?
  teacher           Teacher? @relation(fields: [teacherId], references: [id])
  contentExperience String
  memorablePerson   String
  joinedClub        Boolean  @default(false)
  clubNames         String?
  createdAt         DateTime @default(now())
}

model PointHistory {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  pointType   String
  pointAmount Int
  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([pointType])
}

model GraduationReview {
  id         String   @id @default(cuid())
  userId     String   @unique
  user       User     @relation(fields: [userId], references: [id])
  authorName String
  className  String
  content    String
  createdAt  DateTime @default(now())
}

model AdminRole {
  id          String   @id @default(cuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  grantedById String?
  createdAt   DateTime @default(now())
}

model SiteSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}
