# Neon Pooled connection (Vercel·서버리스 권장)
DATABASE_URL=postgresql://USER:PASSWORD@ep-xxxx-pooler.region.aws.neon.tech/neondb?sslmode=require&pgbouncer=true

NEXTAUTH_URL=http://localhost:3000
AUTH_SECRET=change-this-to-a-random-secret-in-production
DISCORD_CLIENT_ID=your-discord-client-id
DISCORD_CLIENT_SECRET=your-discord-client-secret

# 디스코드 서버 연동 (가입 확인·서버 닉·역할·닉 변경)
# 서버 ID: 디스코드 설정 → 고급 → 개발자 모드 → 서버 우클릭 → 서버 ID 복사
DISCORD_GUILD_ID=your-discord-server-id
# 봇 토큰: Developer Portal → Bot → Reset Token
DISCORD_BOT_TOKEN=your-discord-bot-token

# 졸업면담·관리자 알림 (Discord 채널 웹훅)
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...

# Vercel Cron 등 주기 동기화용 (선택)
CRON_SECRET=change-this-cron-secret
